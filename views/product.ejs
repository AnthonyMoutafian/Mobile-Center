<!DOCTYPE html>
<html lang="en">
<head>
  <title><%= title %></title>
  <link rel="stylesheet" href="/stylesheets/style.css">
</head>
<body>

  <nav class="navigation">
    <div class="container">
      <div class="nav-box">
        <div class="nav-left">
          <a href="/">
            <img
              src="https://www.mobilecentre.am/assets/img/logo.svg"
              alt="Mobile Centre Logo"
            >
          </a>
        </div>

        <div class="nav-center">
          <form action="/search" method="get">
            <input type="text" name="search" placeholder="Search">
            <button type="submit">
              <i class="bi bi-search"></i>
            </button>
          </form>
        </div>

        <div class="nav-right">
          <a>Cart</a>
        </div>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="product-page">

      <div class="product-image">
        <img
          src="<%= product.image %>"
          alt="<%= product.title %>"
        >
      </div>

      <div class="product-info">
        <h1><%= product.title %></h1>

        <h2><%= product.brand %></h2>

        <p>
            <i class="bi bi-star-fill"></i>
            <%= product.rating %>
        </p>

        <p class="price">
          Price:
          <strong><%= product.price.toLocaleString() %> AMD</strong>
        </p>

        <% if (product.isNew) { %>
          <span class="new-badge">NEW</span>
        <% } %>

        <div class="clear">
        </div>

        <% if (product.inStock > 0) { %>
          <p class="availability">Available</p>
        <% } else { %>
          <p class="outofstock">Out Of Stock</p>
        <% } %>
        
        <div class="clear">
        </div>
        

        <button>Buy</button>
      </div>

    </div>

    <hr>

    <h2>Specifications</h2>

    <div class="specifications">
      <% product.params.forEach(param => { %>
        <div class="spec">
          <strong><%= param.title %></strong>
          <span><%= param.desc %></span>
        </div>
      <% }) %>
    </div>

    <hr>

    <h2 class="related-title">Related Products</h2>

    <div class="products">
      <% relatedProducts.forEach(product => { %>
        <a
          href="/product/<%= product.slug %>"
          class="product"
        >
          <img
            src="<%= product.image %>"
            alt="<%= product.title %>"
          >

          <h3><%= product.title %></h3>

          <p class="price">
            <%= product.price.toLocaleString() %> AMD
          </p>

          <button>
            Buy
          </button>
        </a>
      <% }) %>
    </div>

  </div>
  <footer class="footer">
      <div class="container">
          <div class="footerBox">
              <div class="footerLeft">
                <span>Mobile Center</span>
              </div>
              <div class="footerRight">
                <span>© 2026 MobileCentre Art LLC. All Rights Reserved. (AM)</span>
              </div>
          </div>
      </div>
  </footer>
</body>
</html>